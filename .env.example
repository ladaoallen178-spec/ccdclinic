# Environment Variables - Copy to .env and fill in values
# ========================================================

# ==== BACKEND CONFIGURATION ====

# Database connection string (REQUIRED for backend)
# Format: postgresql://username:password@host:port/database?sslmode=require
# 
# Supabase example:
#   postgresql://postgres:your_password@aws-1-region.pooler.supabase.com:5432/postgres?sslmode=require
# 
# Neon example:
#   postgresql://user:password@ep-random.us-east-1.neon.tech/dbname?sslmode=require
# 
# Local Docker example:
#   postgresql://postgres:postgres@localhost:5433/schoolclinic
DATABASE_URL=

# JWT secret key for token signing (REQUIRED for backend)
# Generate a random 32-character hex string:
#   openssl rand -hex 32
JWT_SECRET=

# Frontend URLs allowed to access this backend (REQUIRED for CORS)
# Comma-separated list of allowed origins
# 
# Local development:
#   http://localhost:5173,http://localhost:3000
# 
# Production (single deployment):
#   https://ccdclinic.vercel.app
# 
# Production (main + preview deployments):
#   https://ccdclinic.vercel.app,https://ccdclinic-git-*.vercel.app
# 
# Note: IMPORTANT for fixing CORS "Failed to fetch" errors!
CLIENT_URL=http://localhost:5173,http://localhost:3000

# Logging level (optional, default: info)
# Values: trace, debug, info, warn, error
RUST_LOG=info

# ==== FRONTEND CONFIGURATION ====

# Backend API URL for frontend requests
# 
# Local development:
#   http://localhost:8000
# 
# Production (set in Vercel environment):
#   https://ccdclinic.onrender.com
# 
# Note: This must match your deployed backend URL for production
VITE_API_URL=http://localhost:8000

# Fallback backend URL (used if VITE_API_URL is not set)
VITE_BACKEND_URL=

# Base path for frontend routing (if serving from subdirectory)
# Leave empty for root deployment
VITE_BASE=/

