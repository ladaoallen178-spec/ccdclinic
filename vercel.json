{
  "version": 2,
  "builds": [
    { "src": "clinic-app/package.json", "use": "@vercel/static-build" }
  ],
  "buildCommand": "cd clinic-app && npm install && npm run build",
  "outputDirectory": "clinic-app/dist",
  "routes": [
    { "handle": "filesystem" },
    { "src": "^/(.*)$", "dest": "/index.html" }
  ]
}