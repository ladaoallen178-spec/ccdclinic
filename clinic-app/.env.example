# Frontend Environment Configuration
# Copy this file to .env.local for local development

# API Backend URL (optional - uses default if not set)
# LOCAL DEVELOPMENT: Leave blank or set to http://localhost:8000
# PRODUCTION: Must be set to your deployed backend URL
# Example: https://ccdclinic.onrender.com
VITE_API_URL=http://localhost:8000

# Backend URL (alternative if VITE_API_URL is not used)
# This is a fallback if VITE_API_URL is not set
VITE_BACKEND_URL=

# Base path for routing (if serving from subdirectory)
# Leave empty for root deployment
VITE_BASE=/
